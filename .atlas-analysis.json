  "keyFeatures": [
    "Microsoft Entra ID (Azure AD) JWT authentication",
    "Role-based access control (Employee, Admin, Super Admin)",
    "Request approval workflow for vacations and profile updates",
    "Real-time notifications via Socket.io WebSockets",
    "Employee profile and vacation management",
    "Announcements and documentation system",
    "Admin dashboard with vacation statistics",
    "File upload handling with Multer",
    "MSSQL database integration with Sequelize ORM",
    "OpenAPI/Swagger documentation"
  ],
  "publicApiSurface": [
    "GET /api/empleados/profile - Get authenticated employee profile",
    "GET /api/empleados/:idEmpleado - Get employee by ID (Admin only)",
    "GET /api/empleados/search - Search employees (Admin only)",
    "GET /api/solicitudes - Get requests for current employee",
    "POST /api/solicitudes - Create new request",
    "POST /api/solicitudes/crearSolicitudVacaciones - Create vacation request",
    "POST /api/solicitudes/actualizacion-perfil - Request profile update",
    "PUT /api/solicitudes/:id/aprobar - Approve request (Admin only)",
    "PUT /api/solicitudes/:id/rechazar - Reject request (Admin only)",
    "GET /api/solicitudes/admin/calendario - Get request calendar (Admin only)",
    "GET /api/comunicados - Get active announcements",
    "GET /api/comunicados/:id - Get announcement by ID",
    "POST /api/comunicados/admin - Create announcement (Admin only)",
    "PUT /api/comunicados/admin/:id - Update announcement (Admin only)",
    "GET /api/vacaciones/admin/stats - Get vacation statistics (Admin only)",
    "GET /api/notificaciones - Get user notifications",
    "GET /api/dashboard-admin - Get admin dashboard data",
    "POST /api/uploads - Upload files",
    "WebSocket /socket.io - Real-time notifications"
  ]
